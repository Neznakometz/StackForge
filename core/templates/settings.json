{
  "$comment": "Project settings template. /init copies it to .claude/settings.json and augments it with stack-specific commands (lint/test/build for the chosen stack). Dangerous ones go in deny.",
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(codex review:*)",
      "Bash(codex --version)",
      "Bash(gemini:*)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/*.pem)",
      "Read(**/secrets/**)",
      "Bash(git push --force:*)",
      "Bash(rm -rf /:*)",
      "Bash(curl:*)",
      "Bash(wget:*)"
    ]
  }
}
