{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/dart-format.js\"",
            "commandWindows": "node \"$env:CLAUDE_PLUGIN_ROOT\\hooks\\dart-format.js\"",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/dart-analyze.js\"",
            "commandWindows": "node \"$env:CLAUDE_PLUGIN_ROOT\\hooks\\dart-analyze.js\"",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
